{
  "name": "@nexus-core/common",
  "version": "1.0.0",
  "description": "Shared itilities: env validation, logging, error types, HTTP helpers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.json --emitDeclarationOnly --declaration",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc --noEmit --project tsconfig.exampleCode.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/dotenv": "^8.2.3",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
